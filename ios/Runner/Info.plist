<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
	<dict>
		<key>CFBundleDevelopmentRegion</key>
		<string>$(DEVELOPMENT_LANGUAGE)</string>
		<key>CFBundleDisplayName</key>
		<string>Tap!Match</string>
		<key>CFBundleExecutable</key>
		<string>$(EXECUTABLE_NAME)</string>
		<key>CFBundleIdentifier</key>
		<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
		<key>CFBundleInfoDictionaryVersion</key>
		<string>6.0</string>
		<key>CFBundleName</key>
		<string>Tap!Match</string>
		<key>CFBundlePackageType</key>
		<string>APPL</string>
		<key>CFBundleShortVersionString</key>
		<string>$(FLUTTER_BUILD_NAME)</string>
		<key>CFBundleSignature</key>
		<string>????</string>
		<key>CFBundleVersion</key>
		<string>$(FLUTTER_BUILD_NUMBER)</string>
		<key>LSRequiresIPhoneOS</key>
		<true/>
		<!-- ✅ Export compliance: özel/üçüncü taraf şifreleme kullanılmıyor -->
		<key>ITSAppUsesNonExemptEncryption</key>
		<false/>
		<key>UILaunchStoryboardName</key>
		<string>LaunchScreen</string>
		<key>UIMainStoryboardFile</key>
		<string>Main</string>
		<key>UISupportedInterfaceOrientations</key>
		<array>
			<string>UIInterfaceOrientationPortrait</string>
		</array>
		<key>CADisableMinimumFrameDurationOnPhone</key>
		<true/>
		<key>UIApplicationSupportsIndirectInputEvents</key>
		<true/>
		<key>NSMotionUsageDescription</key>
		<string>This app uses motion sensors to detect device orientation for pairing validation.</string>
		<key>NSBluetoothAlwaysUsageDescription</key>
		<string>Bu uygulama telefonları eşleştirmek için Bluetooth'u kullanır. / This app uses Bluetooth to pair phones.</string>
		<key>NSBluetoothPeripheralUsageDescription</key>
		<string>Bu uygulama telefonları eşleştirmek için Bluetooth Peripheral'ını kullanır. / This app uses Bluetooth Peripheral to pair phones.</string>
		<key>NSLocalNetworkUsageDescription</key>
		<string>Yakındaki cihazları bulmak ve eşleştirmek için yerel ağ erişimi gerekir. / Local network access is required to discover nearby devices and pair.</string>
		<key>NSBonjourServices</key>
		<array>
			<string>_nomatchp2p._tcp</string>
			<string>_nomatchp2p._tcp.</string>
			<string>_nomatchp2p._udp</string>
			<string>_nomatchp2p._udp.</string>
		</array>
		<!-- ✅ NEW: Prefer WiFi over AWDL for connection stability -->
		<key>NSLocalNetworkPrivacyPolicy</key>
		<string>Uses local network to discover nearby devices for peer-to-peer connectivity</string>
		<key>NSMulticastUsageDescription</key>
		<string>Requires multicast for device discovery</string>
		<!-- ✅ Background modes: BLE must run in background for pairing notifications -->
		<key>UIBackgroundModes</key>
		<array>
			<string>bluetooth-central</string>
			<string>bluetooth-peripheral</string>
		</array>
		<key>UIStatusBarHidden</key>
		<true/>
		<key>UIViewControllerBasedStatusBarAppearance</key>
		<false/>
		<!-- ✅ URL Schemes: WhatsApp ve Instagram linklerini açmak için -->
		<key>LSApplicationQueriesSchemes</key>
		<array>
			<string>whatsapp</string>
			<string>instagram</string>
			<string>instagram-stories</string>
			<string>https</string>
		</array>
	</dict>
</plist>
